{
  // Go
  "go.buildOnSave": "package",
  "go.lintOnSave": "package",
  "go.vetOnSave": "package",
  "go.buildFlags": [],
  "go.lintTool": "golangci-lint",
  "go.lintFlags": [
    "--fast",
    "--disable=wsl",
    "--disable=gomnd",
    "--disable=perfsprint",
  ],
  "go.vetFlags": [],
  "go.testFlags": ["-v"],
  "go.testTimeout": "15s",
  "go.coverOnSave": false,
  "go.formatTool": "goimports",
  "go.alternateTools": {
    "go": "/opt/homebrew/bin/go",
  },
  "go.useLanguageServer": true,
  "go.testEnvFile": "",
  // Terraform
  "[terraform]": {
    "editor.defaultFormatter": "hashicorp.terraform",
    "editor.formatOnSave": true,
    "editor.formatOnSaveMode": "file",
  },
  "[terraform-vars]": {
    "editor.defaultFormatter": "hashicorp.terraform",
    "editor.formatOnSave": true,
    "editor.formatOnSaveMode": "file",
  },
  // Bazel
  "bazel.buildifierExecutable": "/opt/homebrew/bin/buildifier",
  "bazel.buildifierFixOnFormat": true,
  // Shellcheck
  "shellcheck.executablePath": "/opt/homebrew/bin/shellcheck",
  // SQL
  "sqltools.formatLanguages": [],
  "sql-formatter.uppercase": true,
  // YAML
  "yaml.schemas": {
    "kubernetes": "manifests/*",
  },
  // Docker
  "[dockerfile]": {
    "editor.defaultFormatter": "ms-azuretools.vscode-docker",
  },
  // Markdown
  "[markdown]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
  },
  // Other
  "editor.cursorBlinking": "smooth",
  "editor.tabSize": 2,
  "editor.glyphMargin": true,
  "editor.lineNumbers": "on",
  "editor.rulers": [100],
  "editor.formatOnType": true,
  "editor.scrollBeyondLastLine": false,
  "editor.fontSize": 12,
  "editor.formatOnSave": true,
  "editor.accessibilitySupport": "off",
  "editor.bracketPairColorization.enabled": false,
  "files.associations": {
    "*.star": "starlark",
  },
  "files.exclude": {
    "**/.tmp": true,
    "**/.git": true,
    "**/.DS_Store": true,
    "go-build/.go": true,
    ".vscode": true,
    "env": true,
    "env_docs": true,
    "**/*.test": true,
    "Godeps/_workspace": true,
    "**/coverage.html": true,
    "**/_build": true,
  },
  "files.trimTrailingWhitespace": true,
  "files.autoSave": "onFocusChange",
  "workbench.iconTheme": null,
  "gitlens.keymap": "chorded",
  "gitlens.advanced.messages": {
    "suppressCommitHasNoPreviousCommitWarning": false,
    "suppressCommitNotFoundWarning": false,
    "suppressFileNotUnderSourceControlWarning": false,
    "suppressGitVersionWarning": false,
    "suppressLineUncommittedWarning": false,
    "suppressNoRepositoryWarning": false,
  },
  "extensions.ignoreRecommendations": false,
  "terminal.integrated.defaultProfile.osx": "bash",
  "terminal.integrated.env.osx": {
    "FIG_NEW_SESSION": "1",
  },
  "go.toolsManagement.autoUpdate": true,
  // Disable gopls colorizations.
  "gopls": {
    "ui.semanticTokens": false,
  },
  "terraform.languageServer.terraform.path": "/opt/homebrew/bin/terraform",
  "shellformat.flag": "-i 2 --binary-next-line --space-redirects",
  "extensions.autoCheckUpdates": false,
  "go.buildTags": "big,integration,cluster_integration",
  "[typescript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
  },
  "[typescriptreact]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
  },
  "js/ts.implicitProjectConfig.module": "NodeNext",

  "claudeCode.preferredLocation": "panel",
  "claudeCode.disableLoginPrompt": true,
  "claudeCode.environmentVariables": [
    {
      "name": "CLAUDE_CODE_USE_VERTEX",
      "value": "1",
    },
    {
      "name": "CLOUD_ML_REGION",
      "value": "global",
    },
    {
      "name": "ANTHROPIC_VERTEX_PROJECT_ID",
      "value": "chronosphere-claude-code",
    },
    {
      "name": "ANTHROPIC_MODEL",
      "value": "claude-fable-5",
    },
    {
      "name": "ANTHROPIC_DEFAULT_HAIKU_MODEL",
      "value": "claude-haiku-4-5@20251001",
    },
    {
      "name": "CLAUDE_CODE_ENABLE_AUTO_MODE",
      "value": "1",
    },
  ],
  "editor.inlineSuggest.enabled": true,
  "githubPullRequests.terminalLinksHandler": "github",
  "githubPullRequests.pullBranch": "never",
  "workbench.colorTheme": "Solarized Light",
  "js/ts.tsdk.path": "ui/node_modules/typescript/lib",
  "terminal.integrated.initialHint": false,
}
